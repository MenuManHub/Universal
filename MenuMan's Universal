-- =========================
-- PVP TAB (REBUILT CLEAN)
-- =========================

local Players = game:GetService("Players")

local HP_ESP_ENABLED = false
local NAME_ESP_ENABLED = false

local HP_TAGS = {}

local function GetCharacterParts(plr)
    if not plr.Character then return end
    local char = plr.Character
    return char:FindFirstChildOfClass("Humanoid"), char:FindFirstChild("Head")
end

local function RemoveTag(plr)
    if HP_TAGS[plr] then
        HP_TAGS[plr]:Destroy()
        HP_TAGS[plr] = nil
    end
end

local function CreateBillboard(plr)
    if plr == LocalPlayer then return end

    RemoveTag(plr)

    local humanoid, head = GetCharacterParts(plr)
    if not humanoid or not head then return end

    -- Billboard
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "PVP_Display"
    billboard.Size = UDim2.new(0, 120, 0, NAME_ESP_ENABLED and 65 or 45)
    billboard.StudsOffset = Vector3.new(0, 2.8, 0)
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = 200
    billboard.Parent = head

    -- Background
    local bg = Instance.new("Frame")
    bg.Size = UDim2.new(1, 0, 1, 0)
    bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    bg.BackgroundTransparency = 0.35
    bg.BorderSizePixel = 0
    bg.Parent = billboard

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 6)
    corner.Parent = bg

    local stroke = Instance.new("UIStroke")
    stroke.Thickness = 1
    stroke.Color = Color3.fromRGB(255, 80, 80)
    stroke.Transparency = 0.4
    stroke.Parent = bg

    local layout = Instance.new("UIListLayout")
    layout.SortOrder = Enum.SortOrder.LayoutOrder
    layout.HorizontalAlignment = Enum.HorizontalAlignment.Center
    layout.VerticalAlignment = Enum.VerticalAlignment.Center
    layout.Parent = bg

    -- NAME (TOP)
    local nameLabel
    if NAME_ESP_ENABLED then
        nameLabel = Instance.new("TextLabel")
        nameLabel.Size = UDim2.new(1, 0, 0, 20)
        nameLabel.BackgroundTransparency = 1
        nameLabel.Text = plr.Name
        nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
        nameLabel.Font = Enum.Font.GothamBold
        nameLabel.TextSize = 13
        nameLabel.TextStrokeTransparency = 0.2
        nameLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        nameLabel.Parent = bg
    end

    -- HP (BOTTOM)
    local hpLabel = Instance.new("TextLabel")
    hpLabel.Size = UDim2.new(1, 0, 0, 20)
    hpLabel.BackgroundTransparency = 1
    hpLabel.TextColor3 = Color3.fromRGB(255, 90, 90)
    hpLabel.Font = Enum.Font.Code
    hpLabel.TextSize = 15
    hpLabel.TextStrokeTransparency = 0.15
    hpLabel.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    hpLabel.Parent = bg

    local function update()
        if not HP_ESP_ENABLED then return end
        if humanoid and humanoid.Parent then
            hpLabel.Text = math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth) .. " HP"
        end
    end

    update()
    humanoid.HealthChanged:Connect(update)

    HP_TAGS[plr] = billboard
end

