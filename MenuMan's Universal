-- =========================
-- CLICK TELEPORT (HOLD KEY + CLICK)
-- =========================

local ClickTeleportEnabled = false
local HoldKeyDown = false

local UIS = game:GetService("UserInputService")

local function GetHRP()
    local char = LocalPlayer.Character
    if not char then return nil end
    return char:FindFirstChild("HumanoidRootPart")
end

local mouse = LocalPlayer:GetMouse()

-- Keybind (changeable)
local ClickTPKey = Enum.KeyCode.F

GameTab:CreateKeybind({
    Name = "Click TP Key",
    CurrentKeybind = "F",
    HoldToInteract = false,
    Flag = "ClickTPKeybind",
    Callback = function(Key)
        if typeof(Key) == "EnumItem" then
            ClickTPKey = Key
        end
    end,
})

-- Toggle
GameTab:CreateToggle({
    Name = "Click Teleport",
    CurrentValue = false,
    Flag = "ClickTeleportToggle",
    Callback = function(Value)
        ClickTeleportEnabled = Value
        HoldKeyDown = false
    end,
})

-- Detect key hold
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if not ClickTeleportEnabled then return end

    if input.KeyCode == ClickTPKey then
        HoldKeyDown = true
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.KeyCode == ClickTPKey then
        HoldKeyDown = false
    end
end)

-- Detect mouse click while holding key
mouse.Button1Down:Connect(function()
    if not ClickTeleportEnabled then return end
    if not HoldKeyDown then return end

    local hrp = GetHRP()
    if not hrp then return end

    local hit = mouse.Hit
    if hit then
        hrp.CFrame = CFrame.new(hit.Position + Vector3.new(0, 3, 0))
    end
end)

